{
  "name": "artifacts",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "devDependencies": {
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "turbo": "^2.9.18",
    "typescript": "5.9.2",
    "ultracite": "7.8.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "@effect/platform-bun": "4.0.0-beta.85",
    "@effect/sql-pg": "4.0.0-beta.85",
    "effect": "4.0.0-beta.85"
  }
}
