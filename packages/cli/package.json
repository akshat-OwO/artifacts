{
  "name": "@akshatowo/artifacts",
  "version": "0.0.3",
  "private": false,
  "description": "CLI for publishing and managing Artifacts.",
  "bin": {
    "artifacts": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --target=bun --production --outfile=dist/index.js --banner='#!/usr/bin/env bun' && chmod +x dist/index.js",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "bun run build && bun run check-types"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.85",
    "better-auth": "^1.6.18",
    "date-fns": "^4.4.0",
    "effect": "4.0.0-beta.85",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
