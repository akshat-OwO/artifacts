{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "bun": "1.3.14",
    "node": "24"
  },
  "steps": {
    "build": {
      "commands": ["bun --cwd apps/web build"]
    }
  },
  "deploy": {
    "startCommand": "bun --cwd apps/start db:migrate && bun --cwd apps/web start"
  }
}
